# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is in .gitignore and will NOT be committed.

# ── Spotify Search ────────────────────────────────────────────────
spotify_credentials_secret_arn = "arn:aws:secretsmanager:us-east-1:ACCOUNT:secret:spotify-XXX"

# Optional: SNS topic for DLQ depth alarms. Empty disables notifications.
alarm_sns_topic_arn = ""

# --- SSM Parameter Store (SecureString) — preferred vendor-key path ---
# deploy.yml seeds these from GitHub environment secrets.
gemini_api_key_ssm_parameter        = "/clouder/gemini/api_key"
openai_api_key_ssm_parameter        = "/clouder/openai/api_key"
tavily_api_key_ssm_parameter        = "/clouder/tavily/api_key"
deepseek_api_key_ssm_parameter      = "/clouder/deepseek/api_key"
spotify_client_id_ssm_parameter     = "/clouder/spotify/client_id"
spotify_client_secret_ssm_parameter = "/clouder/spotify/client_secret"

# --- Aurora IAM auth for migration Lambda (optional) ---
# Flip to "iam" only after alembic migration 20260419_07 applied
# and the clouder_migrator role exists with rds_iam grant.
# migration_aurora_auth_mode = "iam"   # default: "password"
# migration_db_user          = "clouder_migrator"

# ── Spec-A user auth ───────────────────────────────────────────────
admin_spotify_ids                    = "your_spotify_id_here"
# Dev: Vite SPA on localhost — Spotify Developer Dashboard must whitelist
# this exact URL.
# Prod: leave empty (or comment the line out) — auth.tf coalesces to
# https://<cloudfront-domain>/auth/return, which must ALSO be added to
# the Spotify Developer Dashboard Redirect URIs allow-list (manual step).
spotify_oauth_redirect_uri           = "http://localhost:5173/auth/return"
allowed_frontend_redirects           = "/, /dashboard"

# CORS: укажи origin-ы фронта. Пустой список = CORS отключён (только server-to-server).
cors_allowed_origins = ["http://localhost:5173", "http://localhost:3000"]
